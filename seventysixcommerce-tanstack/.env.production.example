# ============================================
# SeventySixCommerce TanStack Start — Production
# ============================================
# Set these values on the production server.
# See deploy-2.md for setup instructions.
# NEVER commit real secrets to source control.

# --- Database (REQUIRED — production PostgreSQL) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# --- External Services ---
# Stripe — USE LIVE KEYS IN PRODUCTION
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Printful — USE REAL API KEY IN PRODUCTION
PRINTFUL_API_KEY=REPLACE_ME
PRINTFUL_WEBHOOK_SECRET=REPLACE_ME

# Brevo — USE REAL API KEY IN PRODUCTION
BREVO_API_KEY=REPLACE_ME

# --- App Configuration ---
BASE_URL=https://commerce-tanstack.seventysixsandbox.com
MOCK_SERVICES=false
VITE_MOCK_SERVICES=false
NODE_ENV=production

# --- Observability (REQUIRED in production) ---
SEVENTYSIX_API_URL=https://seventysixsandbox.com
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# --- Public (baked into client bundle at build time, requires VITE_ prefix) ---
VITE_OTEL_ENDPOINT=https://seventysixsandbox.com/otel
VITE_GA4_MEASUREMENT_ID=G-REPLACE_ME
VITE_GOOGLE_SITE_VERIFICATION=REPLACE_ME
VITE_BING_SITE_VERIFICATION=REPLACE_ME
