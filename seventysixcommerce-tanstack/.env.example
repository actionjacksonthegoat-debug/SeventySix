STRIPE_SECRET_KEY=sk_test_mock_key
STRIPE_WEBHOOK_SECRET=whsec_mock_secret
PRINTFUL_API_KEY=mock_printful_key
PRINTFUL_WEBHOOK_SECRET=mock_webhook_secret
BREVO_API_KEY=mock_brevo_key
BASE_URL=https://localhost:3002
MOCK_SERVICES=true
VITE_MOCK_SERVICES=true

# SeventySix API URL for log forwarding (leave empty to disable)
SEVENTYSIX_API_URL=

# OpenTelemetry OTLP HTTP endpoint for server-side traces/metrics (leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=

# OpenTelemetry OTLP HTTP endpoint for browser-side traces (leave empty to disable)
VITE_OTEL_ENDPOINT=

# Google Analytics 4 measurement ID (leave empty to disable analytics)
VITE_GA4_MEASUREMENT_ID=

# Google Search Console verification code (leave empty to skip)
VITE_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools verification code (leave empty to skip)
VITE_BING_SITE_VERIFICATION=
