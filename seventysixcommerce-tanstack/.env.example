# Database — Auto-generated by start script, or create .env from this template
DATABASE_URL=postgresql://seventysixcommerce:CHANGE_ME_STRONG_PASSWORD@localhost:5438/seventysixcommerce
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Third-party APIs (mock mode uses in-memory stubs, no real keys needed)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_SECRET
PRINTFUL_API_KEY=REPLACE_WITH_YOUR_KEY
PRINTFUL_WEBHOOK_SECRET=REPLACE_WITH_YOUR_KEY
BREVO_API_KEY=REPLACE_WITH_YOUR_KEY

# Application
BASE_URL=https://localhost:3002
MOCK_SERVICES=true
VITE_MOCK_SERVICES=true

# Optional integrations (leave empty to disable)
SEVENTYSIX_API_URL=
OTEL_EXPORTER_OTLP_ENDPOINT=
VITE_OTEL_ENDPOINT=
VITE_GA4_MEASUREMENT_ID=
VITE_GOOGLE_SITE_VERIFICATION=
VITE_BING_SITE_VERIFICATION=
