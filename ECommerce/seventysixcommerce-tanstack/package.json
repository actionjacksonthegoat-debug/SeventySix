{
  "name": "seventysixcommerce-tanstack",
  "version": "1.0.0",
  "description": "SeventySixCommerce art merchandise storefront — TanStack Start",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3002",
    "build": "vite build",
    "start": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "db:generate": "echo 'Usage: npx drizzle-kit generate --name=<descriptive_name>' && exit 1",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/server/db/seed.ts",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "format": "eslint . --fix && dprint fmt && eslint . --fix",
    "lint": "eslint ."
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@seventysixcommerce/shared": "file:../seventysixcommerce-shared",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.5",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.10",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^22.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "dprint": "^0.53.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "h3-v2": "npm:h3@>=2.0.1-rc.18",
    "esbuild": ">=0.25.0"
  }
}
