{
	"name": "SeventySix",
	"image": "mcr.microsoft.com/devcontainers/dotnet:10.0",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "24"
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/powershell:1": {}
	},
	"hostRequirements": {
		"cpus": 4,
		"memory": "16gb",
		"storage": "64gb"
	},
	"forwardPorts": [4200, 7074, 3443, 5051, 16687, 9091, 5541, 5433, 6379, 4319, 3001, 3002, 3011, 3012, 5440, 5441],
	"portsAttributes": {
		"7074": {
			"label": "SeventySix API",
			"protocol": "https",
			"visibility": "public"
		},
		"4200": {
			"label": "Angular Client",
			"protocol": "https",
			"visibility": "public"
		},
		"3443": {
			"label": "Grafana (HTTPS Proxy)",
			"protocol": "https",
			"visibility": "public"
		},
		"16687": {
			"label": "Jaeger (HTTPS Proxy)",
			"protocol": "https",
			"visibility": "public"
		},
		"9091": {
			"label": "Prometheus (HTTPS Proxy)",
			"protocol": "https",
			"visibility": "public"
		},
		"5051": {
			"label": "pgAdmin (HTTPS Proxy)",
			"protocol": "https",
			"visibility": "public"
		},
		"5541": {
			"label": "RedisInsight (HTTPS Proxy)",
			"protocol": "https",
			"visibility": "public"
		},
		"5433": {
			"label": "PostgreSQL",
			"onAutoForward": "silent"
		},
		"6379": {
			"label": "Valkey (Redis)",
			"onAutoForward": "silent"
		},
		"4319": {
			"label": "OTEL Collector (HTTPS Proxy)",
			"protocol": "https",
			"onAutoForward": "silent"
		},
		"3001": {
			"label": "SeventySixCommerce SvelteKit Dev",
			"onAutoForward": "silent"
		},
		"3002": {
			"label": "SeventySixCommerce TanStack Dev",
			"onAutoForward": "silent"
		},
		"3011": {
			"label": "SvelteKit E2E App",
			"onAutoForward": "silent"
		},
		"3012": {
			"label": "TanStack E2E App",
			"onAutoForward": "silent"
		},
		"5440": {
			"label": "SvelteKit E2E PostgreSQL",
			"onAutoForward": "silent"
		},
		"5441": {
			"label": "TanStack E2E PostgreSQL",
			"onAutoForward": "silent"
		}
	},
	"postCreateCommand": "npm install && cd seventysixcommerce-sveltekit && npm ci && cd ../seventysixcommerce-tanstack && npm ci",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-dotnettools.csdevkit",
				"angular.ng-template",
				"ms-playwright.playwright",
				"dbaeumer.vscode-eslint"
			],
			"settings": {
				"terminal.integrated.defaultProfile.linux": "pwsh"
			}
		}
	}
}
