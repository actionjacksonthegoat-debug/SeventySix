{
	// Auto-save settings
	"files.autoSave": "afterDelay",
	"files.autoSaveDelay": 500,

	// Format on save for all file types
	"editor.formatOnSave": true,

	// Respect .editorconfig settings for indentation
	"editor.insertSpaces": false,
	"editor.tabSize": 4,
	"editor.detectIndentation": false,

	// TypeScript/JavaScript settings
	"typescript.preferences.quoteStyle": "double",
	"javascript.preferences.quoteStyle": "double",

	// Default formatters - dprint for all supported file types
	"[typescript]": {
		"editor.defaultFormatter": "dprint.dprint",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.fixAll.eslint": "explicit"
		},
		"files.eol": "\n"
	},
	"[javascript]": {
		"editor.defaultFormatter": "dprint.dprint",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.fixAll.eslint": "explicit"
		},
		"files.eol": "\n"
	},
	"[json]": {
		"editor.defaultFormatter": "dprint.dprint",
		"editor.formatOnSave": true,
		"files.eol": "\n"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "dprint.dprint",
		"editor.formatOnSave": true,
		"files.eol": "\n"
	},
	"[scss]": {
		"editor.defaultFormatter": "dprint.dprint",
		"editor.formatOnSave": true,
		"files.eol": "\n"
	},
	"[css]": {
		"editor.defaultFormatter": "dprint.dprint",
		"editor.formatOnSave": true,
		"files.eol": "\n"
	},
	"[html]": {
		"editor.defaultFormatter": "Angular.ng-template",
		"editor.formatOnSave": true,
		"files.eol": "\n"
	},
	"[csharp]": {
		"editor.formatOnSave": true,
		"files.eol": "\r\n"
	},

	// C# settings (OmniSharp)
	"omnisharp.enableEditorConfigSupport": true,

	// File settings
	"files.trimTrailingWhitespace": true,
	"files.insertFinalNewline": false,

	// Default line ending (LF for cross-platform, overridden per language above)
	"files.eol": "\n",

	// Copilot agent mode auto-fix
	"github.copilot.chat.agent.autoFix": true,

	// Instruction file locations (explicit)
	"chat.instructionsFilesLocations": {
		".github/instructions": true
	},

	// Prompt file locations (explicit)
	"chat.promptFilesLocations": {
		".github/prompts": true
	},

	// Enable mcp — all tools always available, no per-tool confirmation
	"chat.mcp.access": "all",
	"chat.agent.maxRequests": 250,

	// CodeQL extension settings
	"codeQL.runningQueries.maxQueries": 20,
	"codeQL.runningQueries.memory": 4096,
	"codeQL.resultsDisplay.pageSize": 100,

	// Exclude high-churn directories from file watcher (prevents VS Code freezes during load tests)
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/node_modules/**": true,
		"**/dist/**": true,
		"**/coverage/**": true,
		"**/.angular/**": true,
		"**/load-testing/results/**": true,
		"**/load-testing/reports/**": true,
		"**/TestResults/**": true,
		"**/dast-reports/**": true,
		"**/playwright-report/**": true,
		"**/test-results/**": true,
		"**/.svelte-kit/**": true,
		"**/.output/**": true,
		"**/.vinxi/**": true
	},

	// Hide high-churn output directories from Explorer and language servers
	"files.exclude": {
		"**/load-testing/results": true,
		"**/load-testing/reports": true
	},

	// Exclude test output from search results
	"search.exclude": {
		"**/load-testing/results/**": true,
		"**/load-testing/reports/**": true,
		"**/TestResults/**": true,
		"**/dast-reports/**": true,
		"**/coverage/**": true,
		"**/playwright-report/**": true,
		"**/test-results/**": true,
		"**/.svelte-kit/**": true
	}
}
