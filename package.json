{
	"scripts": {
		"postinstall": "npm install --prefix seventysixcommerce-shared && npm install --prefix SeventySix.Client && npm install --prefix SeventySix.Client/load-testing && npm install --prefix SeventySix.Client/mock-brevo-api && npm install --prefix seventysixcommerce-sveltekit && npm install --prefix seventysixcommerce-tanstack",
		"bootstrap": "node scripts/bootstrap.mjs",

		"start": "node scripts/start-all.mjs",
		"start:seventysix": "node scripts/run-pwsh.mjs -File scripts/start-dev.ps1",
		"start:seventysix-api-debug": "node scripts/run-pwsh.mjs -File scripts/start-infrastructure.ps1",
		"start:client": "cd SeventySix.Client && npm start",
		"start:svelte": "node seventysixcommerce-sveltekit/scripts/start.mjs",
		"start:tanstack": "node seventysixcommerce-tanstack/scripts/start.mjs",
		"start:container": "devcontainer up --workspace-folder .",

		"stop": "node scripts/run-pwsh.mjs -File scripts/stop-all.ps1",
		"stop:api": "node scripts/run-pwsh.mjs -File scripts/stop-api.ps1",
		"stop:svelte": "docker compose -f seventysixcommerce-sveltekit/docker-compose.dev.yml down",
		"stop:tanstack": "docker compose -f seventysixcommerce-tanstack/docker-compose.dev.yml down",

		"format": "npm run format:server && npm run format:client && npm run format:shared && npm run format:svelte && npm run format:tanstack",
		"format:server": "cd SeventySix.Server && dotnet build SeventySix.Analyzers.CodeFixes --configuration Release --no-incremental && dotnet build SeventySix.Analyzers --configuration Release --no-incremental && dotnet build && dotnet format analyzers --severity warn && dotnet format && dotnet format",
		"format:client": "cd SeventySix.Client && npm run format",
		"format:shared": "cd seventysixcommerce-shared && npm run format",
		"format:svelte": "cd seventysixcommerce-sveltekit && npm run format",
		"format:tanstack": "cd seventysixcommerce-tanstack && npm run format",

		"lint": "npm run lint:client && npm run lint:svelte && npm run lint:tanstack",
		"lint:client": "cd SeventySix.Client && npm run lint",
		"lint:svelte": "cd seventysixcommerce-sveltekit && npm run lint",
		"lint:tanstack": "cd seventysixcommerce-tanstack && npm run lint",

		"test": "npm run test:server && npm run test:client && npm run test:shared && npm run test:svelte && npm run test:tanstack",
		"test:server": "cd SeventySix.Server && dotnet build && dotnet test",
		"test:client": "cd SeventySix.Client && npm test",
		"test:shared": "cd seventysixcommerce-shared && npm test",
		"test:svelte": "cd seventysixcommerce-sveltekit && npm test",
		"test:tanstack": "cd seventysixcommerce-tanstack && npm test",

		"test:coverage": "npm run test:coverage:server && npm run test:coverage:client && npm run test:coverage:svelte && npm run test:coverage:tanstack",
		"test:coverage:server": "node scripts/run-pwsh.mjs -File scripts/run-server-coverage.ps1",
		"test:coverage:client": "cd SeventySix.Client && npm run test:coverage",
		"test:coverage:svelte": "cd seventysixcommerce-sveltekit && npm run test:coverage",
		"test:coverage:tanstack": "cd seventysixcommerce-tanstack && npm run test:coverage",

		"test:e2e": "cd SeventySix.Client && npm run test:e2e --",
		"test:e2e:keepalive": "cd SeventySix.Client && npm run test:e2e:keepalive --",
		"test:e2e:all": "node scripts/run-e2e-all.mjs",
		"test:e2e:svelte": "cd seventysixcommerce-sveltekit && npm run test:e2e",
		"test:e2e:tanstack": "cd seventysixcommerce-tanstack && npm run test:e2e",

		"test:dast": "node scripts/run-pwsh.mjs -File scripts/run-dast.ps1",

		"loadtest:quick": "node scripts/run-pwsh.mjs -File SeventySix.Client/load-testing/scripts/run-load-tests.ps1 -TestProfile quick",
		"loadtest:smoke": "node scripts/run-pwsh.mjs -File SeventySix.Client/load-testing/scripts/run-load-tests.ps1 -TestProfile smoke",
		"loadtest:load": "node scripts/run-pwsh.mjs -File SeventySix.Client/load-testing/scripts/run-load-tests.ps1 -TestProfile load",
		"loadtest:stress": "node scripts/run-pwsh.mjs -File SeventySix.Client/load-testing/scripts/run-load-tests.ps1 -TestProfile stress",
		"loadtest:svelte:quick": "node scripts/run-pwsh.mjs -File seventysixcommerce-sveltekit/load-testing/scripts/run-load-tests.ps1 -TestProfile quick",
		"loadtest:svelte:smoke": "node scripts/run-pwsh.mjs -File seventysixcommerce-sveltekit/load-testing/scripts/run-load-tests.ps1 -TestProfile smoke",
		"loadtest:svelte:load": "node scripts/run-pwsh.mjs -File seventysixcommerce-sveltekit/load-testing/scripts/run-load-tests.ps1 -TestProfile load",
		"loadtest:svelte:stress": "node scripts/run-pwsh.mjs -File seventysixcommerce-sveltekit/load-testing/scripts/run-load-tests.ps1 -TestProfile stress",
		"loadtest:tanstack:quick": "node scripts/run-pwsh.mjs -File seventysixcommerce-tanstack/load-testing/scripts/run-load-tests.ps1 -TestProfile quick",
		"loadtest:tanstack:smoke": "node scripts/run-pwsh.mjs -File seventysixcommerce-tanstack/load-testing/scripts/run-load-tests.ps1 -TestProfile smoke",
		"loadtest:tanstack:load": "node scripts/run-pwsh.mjs -File seventysixcommerce-tanstack/load-testing/scripts/run-load-tests.ps1 -TestProfile load",
		"loadtest:tanstack:stress": "node scripts/run-pwsh.mjs -File seventysixcommerce-tanstack/load-testing/scripts/run-load-tests.ps1 -TestProfile stress",

		"db:reset": "node scripts/run-pwsh.mjs -File scripts/reset-database.ps1 -Environment dev",

		"secrets:init": "node scripts/run-pwsh.mjs -File scripts/manage-user-secrets.ps1 -Action init",
		"secrets:list": "node scripts/run-pwsh.mjs -File scripts/manage-user-secrets.ps1 -Action list",
		"secrets:set": "node scripts/run-pwsh.mjs -File scripts/manage-user-secrets.ps1 -Action set",
		"secrets:delete": "node scripts/run-pwsh.mjs -File scripts/manage-user-secrets.ps1 -Action delete",

		"generate:dataprotection-cert": "node scripts/run-pwsh.mjs -File scripts/generate-dataprotection-cert.ps1",
		"generate:ssl-cert": "node scripts/run-pwsh.mjs -File scripts/generate-dev-ssl-cert.ps1 -Force",
		"generate:icons": "cd SeventySix.Client && npm run generate:icons",

		"clean:docker": "node scripts/run-pwsh.mjs -File scripts/cleanup-docker.ps1",
		"clean:docker:full": "node scripts/run-pwsh.mjs -File scripts/cleanup-docker.ps1 -IncludeVolumes",

		"scan:codeql:ci": "npm run scan:codeql:ci:typescript && npm run scan:codeql:ci:csharp",
		"scan:codeql:ci:csharp": "docker compose -f docker-compose.codeql.yml --profile csharp up --abort-on-container-exit && docker compose -f docker-compose.codeql.yml down",
		"scan:codeql:ci:typescript": "docker compose -f docker-compose.codeql.yml --profile typescript up --abort-on-container-exit && docker compose -f docker-compose.codeql.yml down",

		"lighthouse": "cd SeventySix.Client && npm run lighthouse:build-run"
	},
	"devDependencies": {
		"@types/node": "^25.3.5",
		"happy-dom": "^20.8.9"
	}
}
