{
	"name": "seventysixcommerce-sveltekit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3001",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "eslint . --fix && dprint fmt && eslint . --fix",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"db:generate": "echo 'Usage: npx drizzle-kit generate --name=<descriptive_name>' && exit 1",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "npx tsx src/lib/server/db/seed.ts",
		"db:up": "docker compose -f docker-compose.dev.yml up -d"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@playwright/test": "^1.58.2",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/svelte": "^5.3.1",
		"@types/pg": "^8.20.0",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"@vitejs/plugin-basic-ssl": "^2.3.0",
		"@vitest/coverage-v8": "^4.1.2",
		"dprint": "^0.53.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.1.0",
		"jsdom": "^29.0.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/auto-instrumentations-node": "^0.72.0",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
		"@opentelemetry/resources": "^2.6.1",
		"@opentelemetry/sdk-metrics": "^2.6.1",
		"@opentelemetry/sdk-node": "^0.214.0",
		"@opentelemetry/sdk-trace-web": "^2.6.1",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.45.1",
		"pg": "^8.20.0",
		"stripe": "^21.0.1",
		"zod": "^4.3.6"
	}
}
